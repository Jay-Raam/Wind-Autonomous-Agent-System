    "dotenv": "17.2.3",
    "express": "4.21.2",
    "express-rate-limit": "7.5.1",
    "helmet": "8.1.0",
    "ioredis": "5.6.1",
    "jsonwebtoken": "9.0.2",
    "mongodb": "7.0.0",
    "mongoose": "8.19.0",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "socket.io": "4.8.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.1",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.13.10",
