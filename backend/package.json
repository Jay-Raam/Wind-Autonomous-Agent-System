{
  "name": "wind-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade backend for autonomous AI agent platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
